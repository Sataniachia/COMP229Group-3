# Environment Configuration for Rapid Tasks Server
# Copy this file to .env and update the values

# Server Configuration
NODE_ENV=development
PORT=4000

# Database Configuration
# For local MongoDB:
MONGODB_URI=mongodb://localhost:27017/rapidtasks
# For MongoDB Atlas (replace with your connection string):
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/rapidtasks

# JWT Configuration
JWT_SECRET=rapid-tasks-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
